---
import { readFileSync } from "node:fs";
import { resolve } from "node:path";
import DataTable from "@components/DataTable.astro";
import { formatCreatedTime } from "@utils/date";
import { escapeHtml } from "@utils/html";

function parseCSV(text: string): Record<string, string>[] {
  const rows: Record<string, string>[] = [];
  let headers: string[] = [];
  let currentRow: string[] = [];
  let currentField = "";
  let inQuotes = false;
  let headerParsed = false;

  for (let i = 0; i < text.length; i++) {
    const ch = text[i];
    const next = text[i + 1];

    if (inQuotes) {
      if (ch === '"') {
        if (next === '"') {
          currentField += '"';
          i++;
        } else {
          inQuotes = false;
        }
      } else {
        currentField += ch;
      }
    } else {
      if (ch === '"') {
        inQuotes = true;
      } else if (ch === ",") {
        currentRow.push(currentField.trim());
        currentField = "";
      } else if (ch === "\n") {
        currentRow.push(currentField.trim());
        currentField = "";
        if (currentRow.length > 1 || currentRow[0] !== "") {
          if (!headerParsed) {
            headers = currentRow;
            headerParsed = true;
          } else {
            const obj: Record<string, string> = {};
            headers.forEach((h, idx) => {
              obj[h] = currentRow[idx] ?? "";
            });
            rows.push(obj);
          }
        }
        currentRow = [];
      } else if (ch === "\r") {
        // skip
      } else {
        currentField += ch;
      }
    }
  }

  if (currentField || currentRow.length > 0) {
    currentRow.push(currentField.trim());
    if (currentRow.length > 1 || currentRow[0] !== "") {
      const obj: Record<string, string> = {};
      headers.forEach((h, idx) => {
        obj[h] = currentRow[idx] ?? "";
      });
      rows.push(obj);
    }
  }

  return rows;
}

const csvPath = resolve("content/anime-from-notion/anime-from-notion.csv");
const csvText = readFileSync(csvPath, "utf-8");
const records = parseCSV(csvText);

const RATING_DISPLAY = ["", "1", "2", "3", "4"];

function renderRating(rating: string): string {
  const n = parseInt(rating) || 0;
  return RATING_DISPLAY[n] || "";
}
---

<div class="anime-table-wrapper">
  <h1>Anime</h1>
  <p class="subtitle">{records.length} entries. Click headers or use the rule bar to sort & filter.</p>

  <DataTable
    data={records}
    defaultSort={[{ key: "开播时间", asc: false }]}
    columns={[
      {
        key: "Name",
        label: "Name",
        render: (row) =>
          escapeHtml(row["Name"]) +
          (row["原名"]
            ? `<small class="at-subtitle">${escapeHtml(row["原名"])}</small>`
            : ""),
        className: "col-name",
      },
      {
        key: "观感",
        label: "Rating",
        type: "number",
        format: (v) => renderRating(String(v)),
        className: "col-rating",
      },
      {
        key: "分类",
        label: "Category",
        render: (row) =>
          row["分类"]
            .split(",")
            .filter(Boolean)
            .map((tag) => `<span class="at-tag">${escapeHtml(tag.trim())}</span>`)
            .join(""),
        className: "col-category",
      },
      {
        key: "开播时间",
        label: "Air Date",
        type: "date",
        format: (v) => formatCreatedTime(v),
        className: "col-date",
      },
      {
        key: "制作公司",
        label: "Studio",
        className: "col-studio",
      },
      {
        key: "comment",
        label: "Comment",
        className: "col-comment",
      },
    ]}
  />
</div>

<style is:global>
  .anime-table-wrapper h1 {
    margin-bottom: 0.5rem;
    font-size: 1.8rem;
  }
  .anime-table-wrapper .subtitle {
    color: var(--gray);
    margin-bottom: 2rem;
    font-size: 0.95rem;
  }

  .anime-table-wrapper td.col-name {
    font-weight: 600;
    min-width: 180px;
  }
  .anime-table-wrapper .at-subtitle {
    display: block;
    font-weight: 400;
    color: #999;
    font-size: 0.8rem;
    margin-top: 2px;
  }
  .anime-table-wrapper td.col-rating {
    white-space: nowrap;
    font-size: 1.1rem;
  }
  .anime-table-wrapper td.col-category {
    min-width: 140px;
  }
  .anime-table-wrapper .at-tag {
    display: inline-block;
    background: #e8f5e9;
    color: var(--dark-mint);
    padding: 1px 6px;
    border-radius: 4px;
    font-size: 0.75rem;
    margin: 1px 2px;
  }
  .anime-table-wrapper td.col-date {
    white-space: nowrap;
    min-width: 100px;
  }
  .anime-table-wrapper td.col-studio {
    min-width: 120px;
  }
  .anime-table-wrapper td.col-comment {
    min-width: 280px;
    max-width: 400px;
    line-height: 1.5;
  }

  @media (max-width: 768px) {
    .anime-table-wrapper td.col-comment {
      max-width: 200px;
    }
  }
</style>
