---
import type { DataTablePayload, Props } from "./types";
import DataTableReact from "./DataTable.client.tsx";

const { data, columns, defaultSort = [] }: Props = Astro.props;

const cols = columns.map((c) => ({
  ...c,
  type: c.type ?? "string",
  sortable: c.sortable ?? true,
  filterable: c.filterable ?? true,
}));

function cellContent(
  c: (typeof cols)[number],
  row: Record<string, any>,
): string {
  const raw = row[c.key];
  if (c.render) return c.render(row);
  if (c.format) return c.format(raw);
  return String(raw ?? "");
}

const payload: DataTablePayload = {
  cols: cols.map((c) => ({
    key: c.key,
    label: c.label,
    type: c.type,
    sortable: c.sortable,
    filterable: c.filterable,
    className: c.className,
  })),
  rows: data.map((row) => ({
    cells: cols.map((c) => ({
      html: cellContent(c, row),
      sortValue: String(row[c.key] ?? ""),
      className: c.className,
    })),
  })),
  defaultSort,
};
---

<DataTableReact client:visible payload={payload} />
