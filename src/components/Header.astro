---
const homeUrl = "/";
---

<nav>
  <div class="bar">
    <a href={homeUrl} class="nav-brand">Mian's</a>
  </div>
</nav>
<style>
  /* Navigation Styles */

  nav {
    background-color: var(--light-gray);
    border-bottom: 1px solid var(--light-gray);
    padding: 1rem 0;
    width: 100%;
  }

  @media (max-width: 480px) {
    nav {
      padding: 0;
    }
  }

  .bar {
    max-width: var(--max-width);
    margin: 0 auto;
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 0 2rem;
    box-sizing: border-box;
  }

  .nav-brand {
    font-family: "Cascadia Code", monospace;
    font-style: normal;
    font-size: 3.4rem;
    color: var(--dark-mint);
    text-decoration: none;
    letter-spacing: -0.02em;
  }

  .nav-brand::after {
    content: "";
    display: inline-block;
    width: 0.4em;
    height: 0.76em;
    background-color: var(--dark-mint);
    margin-left: 0.05em;
    opacity: 0.85;
  }
</style>
