---
import type { CollectionEntry } from "astro:content";
import { isWip } from "@utils/freshness";

interface Props {
  posts: CollectionEntry<"blog">[];
  basePath: string;
}

const { posts, basePath } = Astro.props;
---

<ul class="blog-list">
  {
    posts.map((post) => (
      <li class="blog-list-item">
        <a href={`${basePath}/${post.data.slug}/`} class="blog-list-link">
          {isWip(post) ? `[WIP] ${post.data.title}` : post.data.title}
        </a>
        {Array.isArray(post.data.tags) && post.data.tags.length > 0 && (
          <span class="blog-list-tags">
            {post.data.tags.map((t: string) => `#${t}`).join(" ")}
          </span>
        )}
      </li>
    ))
  }
</ul>

<style>
  .blog-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .blog-list-item {
    display: flex;
    gap: 10px;
    align-items: center;
    justify-content: space-between;
    padding-block: 6px;
  }

  .blog-list-link {
    text-decoration: none;
    color: var(--dark-mint);
    font-size: 1.2rem;
  }

  .blog-list-link:hover {
    text-decoration: underline;
    text-decoration-color: var(--dark-mint);
  }

  .blog-list-title {
    font-size: 1.1rem;
    font-weight: 600;
    line-height: 1.4;
    display: block;
    margin-bottom: 0.25rem;
  }

  .blog-list-tags {
    font-size: 0.9rem;
    color: var(--gray, #999999);
    display: block;
    font-family:
      ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono",
      "Courier New", monospace;
  }

  /* Responsive design */
  @media (max-width: 768px) {
    .blog-list-item {
      flex-wrap: wrap;
    }

    .blog-list-title {
      font-size: 1rem;
    }

    .blog-list-tags {
      font-size: 0.8rem;
    }
  }
</style>
