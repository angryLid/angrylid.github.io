---
const { pathname } = Astro.url;

// Posts is active on "/" and any "/posts/*" page (posts are part of the blog).
const postsActive = pathname === "/" || pathname.startsWith("/posts/");
const thoughtsActive =
  pathname === "/thoughts" || pathname.startsWith("/thoughts/");
---

<nav class="nav-menu" aria-label="Primary">
  <ul>
    <li>
      <a
        href="/thoughts"
        class={`nav-tab ${thoughtsActive ? "active" : ""}`}
        aria-current={thoughtsActive ? "page" : undefined}>Thoughts</a
      >
    </li>
    <li>
      <a
        href="/"
        class={`nav-tab ${postsActive ? "active" : ""}`}
        aria-current={postsActive ? "page" : undefined}>Posts</a
      >
    </li>
  </ul>
</nav>

<style>
  .nav-menu ul {
    list-style: none;
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 2.5rem;
    margin: 0 0 1.5rem;
    padding: 0;
  }

  .nav-tab {
    font-family: "Cascadia Code", monospace;
    font-size: 1.4rem;
    font-weight: 600;
    color: var(--gray);
    text-decoration: none;
    padding: 0.25rem 0.25rem 0.4rem;
    border-bottom: 3px solid transparent;
    letter-spacing: -0.01em;
    transition:
      color 0.15s ease,
      border-color 0.15s ease;
  }

  .nav-tab:hover {
    color: var(--dark-mint);
  }

  .nav-tab.active {
    color: var(--dark-mint);
    border-bottom-color: var(--dark-mint);
  }

  @media (max-width: 480px) {
    .nav-menu ul {
      gap: 1.5rem;
    }
    .nav-tab {
      font-size: 1.5rem;
    }
  }
</style>
