---
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const entries = await getCollection("pres");
  const slugs = [...new Set(entries.map((e) => e.id.split("/")[0]))];
  return slugs.map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta http-equiv="refresh" content={`0; url=/pres/${slug}/1/`} />
    <link rel="canonical" href={`/pres/${slug}/1/`} />
    <title>Redirecting…</title>
  </head>
  <body>
    <p>Redirecting to <a href={`/pres/${slug}/1/`}>slide 1</a>.</p>
  </body>
</html>
