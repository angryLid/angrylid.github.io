---
import IndexLayout from "@layouts/IndexLayout.astro";
import BlogList from "@components/BlogList.astro";
import { getCollection } from "astro:content";
import { byFreshness } from "@utils/freshness";

const posts = (await getCollection("blog")).sort(byFreshness);
---

<IndexLayout title="Posts">
  <BlogList posts={posts} basePath="/posts" />
</IndexLayout>
