---
import 'github-markdown-css/github-markdown.css';
import Layout from '@layouts/Layout.astro';

---
  <style>
      /* Layout */
      .container {
        box-sizing: border-box;
        min-width: 200px;
        max-width: 980px;
        margin: 0 auto;
        padding: 45px;
      }
      .container {
		:is(h1, h2, h3, h4, h5, h6){
			color: var(--dark-mint);
		}
    
	}
  .container {
      background: var(--white);
    }
    </style>
<Layout>
    <main class="container">
      <slot />
    </main>
</Layout>