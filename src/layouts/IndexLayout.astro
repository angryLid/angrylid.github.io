---
import Layout from "@layouts/Layout.astro";
import NavMenu from "@components/NavMenu.astro";

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<style>
  /* Layout */
  .container {
    box-sizing: border-box;
    min-width: 200px;
    max-width: 980px;
    margin: 0 auto;
    padding: 45px;
  }
  .container {
    :is(h1, h2, h3, h4, h5, h6) {
      color: var(--dark-mint);
    }
  }
  .container {
    background: var(--white);
  }
  @media (max-width: 480px) {
    .container {
      padding: 20px;
    }
  }

  /* Screen-reader-only: visually hidden but available to AT and SEO. */
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>
<Layout title={title}>
  <main class="container">
    <h1 class="sr-only">{title}</h1>
    <NavMenu />
    <slot />
  </main>
</Layout>
