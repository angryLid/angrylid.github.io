---
import { ClientRouter } from "astro:transitions";

interface Props {
  slug: string;
  pageNo: number;
  total: number;
  steps: number;
  presTitle: string;
  title: string;
}

const { slug, pageNo, total, steps, presTitle, title } = Astro.props;
const fullTitle = `${presTitle} — ${title} (${pageNo}/${total})`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{fullTitle}</title>

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cascadia+Code:ital,wght@0,200..700;1,200..700&display=swap"
      rel="stylesheet"
    />

    <ClientRouter />

    <style is:global>
      :root {
        --mint-green: #90ee90;
        --dark-mint: #228b22;
        --white: #ffffff;
        --light-gray: #fafaf7;
        --gray: #666666;
        --border-radius: 8px;
      }

      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      html,
      body {
        height: 100%;
        overflow: hidden;
      }

      body {
        font-family:
          -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Oxygen, Ubuntu,
          Cantarell, sans-serif;
        line-height: 1.6;
        color: var(--gray);
        background-color: var(--light-gray);
        display: flex;
        align-items: center;
        justify-content: center;
      }

      .slide {
        width: 100%;
        max-width: 1200px;
        padding: 2rem;
        text-align: center;
      }

      /* data-anim / data-step system.
         opacity-based (not display:none) so revealed-at-step-0 content and
         hidden content both stay in the a11y tree. */
      [data-anim] {
        opacity: 0;
        transition:
          opacity 0.3s ease,
          transform 0.3s ease;
      }
      [data-anim][data-visible] {
        opacity: 1;
      }

      .slide :is(h1, h2, h3, h4, h5, h6) {
        color: var(--dark-mint);
      }

      /* Slide-level indicator (bottom-right) */
      .pres-indicator {
        position: fixed;
        right: 1rem;
        bottom: 0.75rem;
        font-size: 0.8rem;
        color: var(--gray);
        opacity: 0.6;
        font-family: "Cascadia Code", monospace;
      }
    </style>
  </head>
  <body
    data-slug={slug}
    data-page-no={String(pageNo)}
    data-total={String(total)}
    data-steps={String(steps)}
    data-step="0"
  >
    <main class="slide">
      <slot />
    </main>
    <div class="pres-indicator">{pageNo} / {total}</div>
  </body>
</html>

<script>
  import { navigate } from "astro:transitions/client";

  // ---------------- BroadcastChannel (module scope; survives swaps) ----------------
  // Syncs the main slide window with the presenter-view popup. BC does not echo
  // back to the sender, so broadcasting on local action + applying silently on
  // receive cannot loop.
  const channel = new BroadcastChannel("pres-speaker");
  let navigatingTo: number | null = null; // destination pageNo during in-flight navigate
  let pendingStep: number | null = null; // step to apply once that page loads
  let navSource: "local" | "sync" | null = null; // who triggered the in-flight navigate

  function currentSlug(): string {
    return document.body.dataset.slug ?? "";
  }
  function readState() {
    const b = document.body;
    return {
      slug: b.dataset.slug ?? "",
      pageNo: parseInt(b.dataset.pageNo ?? "", 10),
      step: parseInt(b.dataset.step ?? "0", 10),
      total: parseInt(b.dataset.total ?? "0", 10),
    };
  }
  function broadcastState(): void {
    const s = readState();
    if (!s.slug) return;
    channel.postMessage({ kind: "state", ...s });
  }

  channel.onmessage = (e: MessageEvent) => {
    const msg = e.data;
    if (!msg || msg.slug !== currentSlug()) return;
    if (msg.kind === "request-state") {
      broadcastState();
      return;
    }
    if (msg.kind !== "state") return;
    const body = document.body;
    if (!body.dataset.slug) return;
    const myPage = parseInt(body.dataset.pageNo ?? "", 10);
    if (navigatingTo != null) {
      // mid-navigate: only remember the destination step, ignore the rest
      if (msg.pageNo === navigatingTo) pendingStep = msg.step;
      return;
    }
    if (msg.pageNo !== myPage) {
      navigatingTo = msg.pageNo;
      navSource = "sync";
      pendingStep = msg.step;
      navigate(`/pres/${currentSlug()}/${msg.pageNo}/`);
    } else {
      setStep(msg.step); // silent apply, no re-broadcast
    }
  };

  // ---------------- slide helpers ----------------
  function computeSteps(body: HTMLElement): number {
    const fm = parseInt(body.dataset.steps ?? "", 10) || 1;
    let maxAnim = 0;
    body.querySelectorAll("[data-anim]").forEach((el) => {
      const n = parseInt(el.getAttribute("data-anim") ?? "", 10);
      if (!Number.isNaN(n) && n > maxAnim) maxAnim = n;
    });
    return Math.max(fm, maxAnim + 1);
  }

  function syncVisibility(body: HTMLElement, step: number): void {
    body.querySelectorAll("[data-anim]").forEach((el) => {
      const n = parseInt(el.getAttribute("data-anim") ?? "", 10);
      if (!Number.isNaN(n) && n <= step) {
        el.setAttribute("data-visible", "");
      } else {
        el.removeAttribute("data-visible");
      }
    });
  }

  function setStep(step: number): void {
    const body = document.body;
    body.dataset.step = String(step);
    syncVisibility(body, step);
  }

  function goNext(): void {
    const body = document.body;
    const pageNo = parseInt(body.dataset.pageNo ?? "", 10);
    const total = parseInt(body.dataset.total ?? "", 10);
    const steps = computeSteps(body);
    const step = parseInt(body.dataset.step ?? "0", 10);
    if (step < steps - 1) {
      setStep(step + 1);
      broadcastState();
    } else if (pageNo < total) {
      navigatingTo = pageNo + 1;
      navSource = "local";
      pendingStep = null;
      navigate(`/pres/${currentSlug()}/${pageNo + 1}/`);
    }
  }

  function goPrev(): void {
    const body = document.body;
    const pageNo = parseInt(body.dataset.pageNo ?? "", 10);
    const step = parseInt(body.dataset.step ?? "0", 10);
    if (step > 0) {
      setStep(step - 1);
      broadcastState();
    } else if (pageNo > 1) {
      // own-keyboard back-nav: same-window restore flag still works
      sessionStorage.setItem(
        `pres-restore-${currentSlug()}-${pageNo - 1}`,
        "last",
      );
      navigatingTo = pageNo - 1;
      navSource = "local";
      pendingStep = null;
      navigate(`/pres/${currentSlug()}/${pageNo - 1}/`);
    }
  }

  function openPresenter(): void {
    const s = readState();
    if (!s.slug) return;
    window.open(
      `/pres/${s.slug}/presenter/?page=${s.pageNo}`,
      "pres-speaker",
      "width=1280,height=800",
    );
  }

  function initSlide(): void {
    const body = document.body;
    if (!body.dataset.slug) return;

    const slug = body.dataset.slug;
    const pageNo = parseInt(body.dataset.pageNo ?? "", 10);
    const steps = computeSteps(body);

    let step = 0;
    // Back-nav restore (own-keyboard): previous page set the flag → land on last step.
    const restoreKey = `pres-restore-${slug}-${pageNo}`;
    if (sessionStorage.getItem(restoreKey) === "last") {
      step = steps - 1;
      sessionStorage.removeItem(restoreKey);
    }

    // Sync-driven navigation overrides the step with the carried pendingStep.
    const wasNav = navigatingTo === pageNo;
    const source = navSource;
    if (wasNav) {
      navigatingTo = null;
      navSource = null;
    }
    if (wasNav && pendingStep != null) {
      step = pendingStep;
      pendingStep = null;
    }

    body.dataset.step = String(step);
    syncVisibility(body, step);

    // Only broadcast for local navigations; sync navigations stay silent.
    if (wasNav && source === "local") broadcastState();
  }

  function onKeyDown(e: KeyboardEvent): void {
    const body = document.body;
    if (!body.dataset.slug) return;

    // Shift+Enter toggles fullscreen on the presentation.
    if (e.key === "Enter" && e.shiftKey) {
      e.preventDefault();
      if (document.fullscreenElement) {
        void document.exitFullscreen();
      } else {
        void document.documentElement.requestFullscreen().catch(() => {});
      }
      return;
    }

    // Shift+S opens the presenter-view popup.
    if (e.key === "S" && e.shiftKey && !e.ctrlKey && !e.metaKey && !e.altKey) {
      e.preventDefault();
      openPresenter();
      return;
    }

    if (e.key === "ArrowRight" || e.key === "ArrowDown") {
      e.preventDefault();
      goNext();
    } else if (e.key === "ArrowLeft" || e.key === "ArrowUp") {
      e.preventDefault();
      goPrev();
    }
  }

  // Bundled module script runs once per session. document persists across
  // view-transition swaps, so these listeners survive all navigations without
  // accumulating. astro:page-load re-initializes per page using fresh body data.
  document.addEventListener("astro:page-load", initSlide);
  document.addEventListener("keydown", onKeyDown);
</script>
